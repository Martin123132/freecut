{
  "name": "freecut",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first open-source short-form video editor with FFmpeg exports.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"node server/index.mjs\" \"vite --host 127.0.0.1\"",
    "dev:api": "node server/index.mjs",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/doctor.ps1",
    "qa:import-transition": "npm run build && playwright test tests/freecut-import-transition.spec.ts",
    "qa:smoke": "npm run build && playwright test tests/project-schema.spec.ts tests/freecut-import-transition.spec.ts tests/freecut-export-job.spec.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^0.475.0",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "AGPL-3.0-only"
}
